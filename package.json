{
  "name": "zod-crud-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @zod-crud/site",
    "build": "npm run build -w zod-crud && npm run build -w @zod-crud/site && npm run build -w @zod-crud/outliner && npm run build -w @zod-crud/mobile-cms",
    "test": "npm test -w zod-crud",
    "typecheck": "npm run typecheck -w zod-crud && npm run typecheck -w @zod-crud/site && npm run typecheck -w @zod-crud/outliner && npm run typecheck -w @zod-crud/mobile-cms",
    "smoke:package": "npm run smoke:package -w zod-crud",
    "verify": "npm run typecheck && npm test && npm run build && npm run smoke:package",
    "pack:library": "npm pack -w zod-crud",
    "site:dev": "npm run dev -w @zod-crud/site",
    "site:build": "npm run build -w @zod-crud/site",
    "outliner:dev": "npm run dev -w @zod-crud/outliner",
    "outliner:build": "npm run build -w @zod-crud/outliner",
    "mobile-cms:dev": "npm run dev -w @zod-crud/mobile-cms",
    "mobile-cms:build": "npm run build -w @zod-crud/mobile-cms"
  },
  "version": "1.0.0",
  "description": "A Zod-guarded JSON tree library locked to **RFC 6901 (JSON Pointer)** and **RFC 6902 (JSON Patch)**. State, actions, and change records are 100% serializable JSON. The core is pure functions; React is confined to one hook.",
