{
  "name": "zod-crud-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build -w zod-crud",
    "dev": "npm run dev -w @zod-crud/showcase",
    "showcase": "npm run dev -w @zod-crud/showcase",
    "showcase:build": "npm run build -w @zod-crud/showcase",
    "test": "npm test -w zod-crud",
    "typecheck": "npm run typecheck -w zod-crud && npm run typecheck -w @zod-crud/showcase",
    "smoke:package": "npm run smoke:package -w zod-crud",
    "verify": "npm run typecheck && npm test && npm run build && npm run showcase:build && npm run smoke:package",
    "pack:library": "npm pack -w zod-crud"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^5.0.0",
    "vite": "^7.3.2",
    "vitest": "^3.0.0",
    "zod": "^4.0.0"
  }
}
