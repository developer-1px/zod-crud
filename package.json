{
  "name": "zod-crud-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w zod-crud",
    "test": "npm test -w zod-crud",
    "typecheck": "npm run typecheck -w zod-crud",
    "smoke:package": "npm run smoke:package -w zod-crud",
    "verify": "npm run typecheck && npm test && npm run build && npm run smoke:package",
    "pack:library": "npm pack -w zod-crud"
  }
}
