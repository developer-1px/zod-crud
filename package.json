{
  "name": "zod-crud",
  "version": "0.1.0",
  "description": "Flat JSON CRUD, clipboard, and history primitives guarded by Zod schemas.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "vite --host 127.0.0.1",
    "demo": "vite --host 127.0.0.1",
    "demo:build": "vite build",
    "prepack": "npm run build",
    "smoke:package": "node ./test/package-smoke.mjs",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "verify": "npm run typecheck && npm test && npm run build && npm run demo:build && npm run smoke:package"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^5.0.0",
    "vite": "^7.3.2",
    "vitest": "^3.0.0",
    "zod": "^4.0.0"
  }
}
