{
  "name": "@interactive-os/json-document-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run playground:dev",
    "build": "npm run build -w @interactive-os/json-document",
    "test": "npm test -w @interactive-os/json-document",
    "typecheck": "npm run typecheck -w @interactive-os/json-document",
    "smoke:package": "npm run smoke:package -w @interactive-os/json-document",
    "extensions:typecheck": "node scripts/run-workspace-scripts.mjs packages typecheck --exclude @interactive-os/json-document",
    "extensions:test": "node scripts/run-workspace-scripts.mjs packages test --exclude @interactive-os/json-document",
    "extensions:build": "node scripts/run-workspace-scripts.mjs packages build --exclude @interactive-os/json-document",
    "extensions:check": "node scripts/evaluate-extensions.mjs",
    "extensions:verify": "npm run extensions:check && npm run extensions:typecheck && npm run extensions:test && npm run extensions:build",
    "labs:extensions:check": "node scripts/evaluate-extension-lab.mjs",
    "labs:extensions:verify": "node scripts/evaluate-extension-lab.mjs --verify",
    "labs:extensions:verify:changed": "node scripts/evaluate-extension-lab.mjs --verify --changed",
    "perf:core": "npm run build -w @interactive-os/json-document && node scripts/benchmark-core.mjs",
    "release:check": "npm run verify && npm run standard:check && npm run perf:core && npm run pack:library",
    "standard:check": "node scripts/evaluate-standardization.mjs && npm test -w @interactive-os/json-document -- standard-conformance",
    "verify": "npm run typecheck && npm test && npm run build && npm run smoke:package && npm run extensions:verify && npm run labs:extensions:verify && npm run docs:evaluate && npm run playground:typecheck && npm run playground:test && npm run playground:build && npm run site:evaluate && npm run site:verify:pages && npm run browser:test",
    "pack:library": "npm pack -w @interactive-os/json-document --cache ./.npm-cache",
    "playground:dev": "npm run dev -w @interactive-os/json-document-site",
    "playground:build": "node scripts/run-workspace-scripts.mjs apps build --if-present",
    "playground:typecheck": "node scripts/run-workspace-scripts.mjs apps typecheck",
    "playground:test": "node scripts/run-workspace-scripts.mjs apps test",
    "browser:test": "playwright test",
    "browser:test:headed": "playwright test --headed",
    "browser:install": "playwright install chromium",
    "docs:generate": "node scripts/generate-docs.mjs",
    "docs:check": "node scripts/generate-docs.mjs --check",
    "docs:evaluate": "npm run docs:check && node scripts/evaluate-docs.mjs",
    "site:evaluate": "node scripts/evaluate-site.mjs",
    "site:build:pages": "SITE_BASE=/json-document/ SITE_URL=https://developer-1px.github.io/json-document VITE_SITE_URL=https://developer-1px.github.io/json-document npm run build -w @interactive-os/json-document-site",
    "site:evaluate:pages": "SITE_BASE=/json-document/ SITE_URL=https://developer-1px.github.io/json-document npm run site:evaluate",
    "site:smoke:pages": "SITE_BASE=/json-document/ SITE_URL=https://developer-1px.github.io/json-document node scripts/evaluate-site-http.mjs",
    "site:verify:pages": "npm run site:build:pages && npm run site:evaluate:pages && npm run site:smoke:pages",
    "site:evaluate:live": "node scripts/evaluate-live-site.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
