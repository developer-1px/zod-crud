{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "useDefineForClassFields": true,
    "paths": {
      "zod-crud/react": ["../../packages/zod-crud/src/api/react.ts"],
      "zod-crud": ["../../packages/zod-crud/src/api/index.ts"]
    }
  },
  "include": ["src"]
}
