{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "useDefineForClassFields": true,
    "paths": {
      "@zod-crud/clipboard-web": ["../../packages/clipboard-web/src/index.ts"],
      "@zod-crud/collection": ["../../packages/collection/src/index.ts"],
      "@zod-crud/dirty-state": ["../../packages/dirty-state/src/index.ts"],
      "@zod-crud/outline": ["../../packages/outline/src/index.ts"],
      "@zod-crud/persist-web": ["../../packages/persist-web/src/index.ts"],
      "zod-crud/react": ["../../packages/zod-crud/src/react.ts"],
      "zod-crud": ["../../packages/zod-crud/src/index.ts"]
    }
  },
  "include": ["src"]
}
