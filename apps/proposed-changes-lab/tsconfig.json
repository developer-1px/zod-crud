{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "useDefineForClassFields": true,
    "paths": {
      "@zod-crud/proposed-changes": ["../../labs/extensions/proposed-changes/src/index.ts"],
      "zod-crud/react": ["../../packages/zod-crud/src/react.ts"],
      "zod-crud": ["../../packages/zod-crud/src/index.ts"]
    }
  },
  "include": ["src"]
}
