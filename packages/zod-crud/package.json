{
  "name": "zod-crud",
  "version": "1.0.0",
  "description": "Headless JSON editing primitives guarded by Zod schemas.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "homepage": "https://developer-1px.github.io/zod-crud/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/developer-1px/zod-crud.git",
    "directory": "packages/zod-crud"
  },
  "bugs": {
    "url": "https://github.com/developer-1px/zod-crud/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "zod",
    "json",
    "crud",
    "schema",
    "tree",
    "treegrid",
    "clipboard",
    "undo",
    "redo",
    "headless"
  ],
  "files": [
    "dist",
    "README.md",
    "SPEC.md",
    "public-contract.json",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "prepack": "npm run build",
    "prepublishOnly": "npm --prefix ../.. run release:check",
    "smoke:package": "node ./tests/smoke/package-smoke.mjs",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "verify": "npm run typecheck && npm test && npm run build && npm run smoke:package"
  },
  "peerDependencies": {
    "react": ">=18",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.7",
    "zod": "^4.0.0"
  }
}
