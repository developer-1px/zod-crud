{
  "name": "zod-crud",
  "version": "0.12.0",
  "description": "Flat JSON CRUD, clipboard, and history primitives guarded by Zod schemas.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "homepage": "https://developer-1px.github.io/zod-crud/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/developer-1px/zod-crud.git",
    "directory": "packages/zod-crud"
  },
  "bugs": {
    "url": "https://github.com/developer-1px/zod-crud/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "zod",
    "json",
    "crud",
    "schema",
    "tree",
    "treegrid",
    "clipboard",
    "undo",
    "redo",
    "headless"
  ],
  "files": [
    "dist",
    "README.md",
    "SPEC.md",
    "STANDARDS.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./verbs/copy": {
      "types": "./dist/verbs/copy.d.ts",
      "import": "./dist/verbs/copy.js"
    },
    "./verbs/duplicate": {
      "types": "./dist/verbs/duplicate.d.ts",
      "import": "./dist/verbs/duplicate.js"
    },
    "./verbs/paste": {
      "types": "./dist/verbs/paste.d.ts",
      "import": "./dist/verbs/paste.js"
    },
    "./verbs/cut": {
      "types": "./dist/verbs/cut.d.ts",
      "import": "./dist/verbs/cut.js"
    },
    "./verbs/find": {
      "types": "./dist/verbs/find.d.ts",
      "import": "./dist/verbs/find.js"
    },
    "./verbs/move": {
      "types": "./dist/verbs/move.d.ts",
      "import": "./dist/verbs/move.js"
    },
    "./verbs/redo": {
      "types": "./dist/verbs/redo.d.ts",
      "import": "./dist/verbs/redo.js"
    },
    "./verbs/replace": {
      "types": "./dist/verbs/replace.d.ts",
      "import": "./dist/verbs/replace.js"
    },
    "./verbs/select": {
      "types": "./dist/verbs/select.d.ts",
      "import": "./dist/verbs/select.js"
    },
    "./verbs/undo": {
      "types": "./dist/verbs/undo.d.ts",
      "import": "./dist/verbs/undo.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "prepack": "npm run build",
    "prepublishOnly": "npm run verify",
    "smoke:package": "node ./test/package-smoke.mjs",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "verify": "npm run typecheck && npm test && npm run build && npm run smoke:package"
  },
  "peerDependencies": {
    "react": ">=18",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0",
    "zod": "^4.0.0"
  }
}
