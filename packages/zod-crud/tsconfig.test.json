{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "paths": {
      "zod-crud": [
        "./src/index.ts"
      ],
      "zod-crud/react": [
        "./src/react.ts"
      ]
    },
    "types": [
      "node"
    ],
    "noEmit": true,
    "rootDir": ".",
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "vitest.config.ts"
  ]
}
