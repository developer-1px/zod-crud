{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "node"
    ],
    "noEmit": true,
    "rootDir": ".",
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "tests/**/*.test-d.ts",
    "tests/document-ops-restore.test.ts",
    "tests/facade-verbs.test.ts",
    "tests/http.test.ts",
    "tests/issue-57-structural-sharing.test.ts",
    "tests/jsonpath.test.ts",
    "tests/package-exports.test.ts",
    "tests/recorder.test.ts",
    "tests/rfc6901-uri-fragment.test.ts",
    "tests/rfc6902-conformance.test.ts",
    "tests/schema-gate.test.ts",
    "tests/standards-coverage.test.ts",
    "tests/verbs.test.ts",
    "tests/verbs-closure.test.ts",
    "vitest.config.ts"
  ]
}
