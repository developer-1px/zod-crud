{
  "permissions": {
    "allow": [
      "Bash(git push *)",
      "Bash(git *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/auto-commit-stop.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": ".claude/hooks/domain-dictionary-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
